{
  "expo": {
    "name": "FindMyBins",
    "slug": "findmybins",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "findmybins",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.six47.findmybins",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:findmybins.com"
      ]
    },
    "android": {
      "package": "com.six47.findmybins",
      "adaptiveIcon": {
        "backgroundColor": "#0F2A43",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "findmybins.com",
              "pathPrefix": "/q"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "FindMyBins uses the camera to scan container QR labels."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "FindMyBins uses the camera to photograph containers and their contents.",
          "photosPermission": "FindMyBins uses your photo library to attach photos to containers."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F2A43",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-sqlite",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
