{
  "name": "WorkspaceMember",
  "type": "object",
  "title": "Workspace Member",
  "description": "Membership of a user in a workspace with a workspace-level role. Removal sets status=removed and revokes access immediately.",
  "properties": {
    "workspace_id": { "type": "string" },
    "user_id": { "type": "string" },
    "user_email": { "type": "string", "format": "email" },
    "member_role": { "type": "string", "enum": ["owner", "admin", "manager", "contributor", "viewer", "billing_admin"] },
    "status": { "type": "string", "enum": ["active", "removed"], "default": "active" },
    "invited_by_user_id": { "type": "string" },
    "joined_at": { "type": "string", "format": "date-time" },
    "removed_at": { "type": "string", "format": "date-time" }
  },
  "required": ["workspace_id", "user_id", "member_role"],
  "rls": { "create": false, "read": false, "update": false, "delete": false }
}
